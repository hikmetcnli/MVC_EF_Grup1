@using MVC_EF_Grup1.Models
@model List<Product>

    <div class="col-lg-12" style="text-align:right">
        <a href="/Home/UrunEkle" class="btn btn-success">Ürün Ekle</a>
    </div>


<table class="table table-striped">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Description</th>
            <th scope="col">Price</th>
            <th scope="col">İşlem</th>
        </tr>
    </thead>
    <tbody>

        @foreach(var item in Model)
        {
            <tr>
                <th scope="row"> @item.Id </th>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td><a href="/Home/UrunEkle/@item.Id" class="btn btn-warning">Düzenle</a>
                    <a href="/Home/UrunSil/@item.Id" class="btn btn-danger">Sil</a>
                </td>
               
            </tr>
        } 
    </tbody>
</table>